{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://selfhelp.app/schemas/plugin-registry.schema.json",
    "title": "SelfHelp plugin registry (canonical v1.0)",
    "description": "Schema for registry.json files served as a SelfHelp plugin source. One canonical schema across the public registry, private registries, and the embedded ResolvedSource the backend hands to the installer. See docs/plugins/registry-and-channels.md.",
    "type": "object",
    "required": ["schemaVersion", "plugins"],
    "additionalProperties": false,
    "properties": {
        "schemaVersion": {
            "type": "string",
            "enum": ["1.0"]
        },
        "publishedAt": {
            "type": "string",
            "format": "date-time"
        },
        "baseUrl": {
            "type": "string",
            "format": "uri",
            "pattern": "^https?://",
            "description": "Public base URL where this registry is served (with trailing slash). Plugin publishers join this to relative `artifacts/<id>-<version>/...` paths to produce the absolute `runtime.entrypointUrl` / `runtime.stylesheetUrl` that gets signed and shipped in each plugin entry."
        },
        "publisher": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "name": {"type": "string", "minLength": 1},
                "url":  {"type": "string", "format": "uri"}
            },
            "required": ["name"]
        },
        "plugins": {
            "type": "array",
            "items": {"$ref": "#/$defs/pluginEntry"}
        }
    },
    "$defs": {
        "pluginEntry": {
            "type": "object",
            "required": ["id", "name", "version", "trustLevel", "composer", "runtime", "checksums", "signature", "signedPayload", "keyId"],
            "additionalProperties": false,
            "properties": {
                "id":            {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
                "name":          {"type": "string", "minLength": 1},
                "description":   {"type": "string"},
                "version":       {"type": "string", "minLength": 1},
                "channel":       {"type": "string", "enum": ["stable", "beta", "alpha", "nightly"]},
                "trustLevel":    {"type": "string", "enum": ["official", "reviewed", "untrusted"]},
                "homepage":      {"type": "string", "format": "uri"},
                "manifestUrl":   {"type": "string"},
                "compatibility": {
                    "type": "object",
                    "required": ["selfhelp"],
                    "additionalProperties": false,
                    "properties": {
                        "selfhelp":    {"type": "string"},
                        "php":         {"type": "string"},
                        "node":        {"type": "string"},
                        "react":       {"type": "string"},
                        "reactNative": {"type": "string"},
                        "expoSdk":     {"type": "string"}
                    }
                },
                "composer": {
                    "type": "object",
                    "required": ["package", "version"],
                    "additionalProperties": false,
                    "properties": {
                        "package": {"type": "string"},
                        "version": {"type": "string"},
                        "repository": {
                            "type": "object",
                            "required": ["type", "url"],
                            "additionalProperties": false,
                            "properties": {
                                "type": {"type": "string", "enum": ["vcs", "path", "composer", "git"]},
                                "url":  {"type": "string"},
                                "reference": {"type": "string"}
                            }
                        }
                    }
                },
                "runtime": {
                    "type": "object",
                    "required": ["entrypointUrl", "format"],
                    "additionalProperties": false,
                    "properties": {
                        "entrypointUrl":       {
                            "type": "string",
                            "format": "uri",
                            "pattern": "^https?://",
                            "description": "Absolute https URL of the published ESM bundle. The host frontend imports this directly via `import()`. Publishers MUST join the registry `baseUrl` to their relative `artifacts/<id>-<version>/plugin.esm.js` path before signing."
                        },
                        "stylesheetUrl":       {
                            "type": "string",
                            "format": "uri",
                            "pattern": "^https?://",
                            "description": "Absolute https URL of the optional published stylesheet."
                        },
                        "format":              {"type": "string", "enum": ["esm"]},
                        "integrity":           {"type": "string"},
                        "stylesheetIntegrity": {"type": "string"}
                    }
                },
                "checksums": {
                    "type": "object",
                    "required": ["frontendEsm"],
                    "additionalProperties": false,
                    "properties": {
                        "frontendEsm": {"type": "string", "pattern": "^sha256-[A-Fa-f0-9]{64}$|^sha256:[A-Fa-f0-9]{64}$|^[A-Fa-f0-9]{64}$"},
                        "frontendCss": {"type": "string", "pattern": "^sha256-[A-Fa-f0-9]{64}$|^sha256:[A-Fa-f0-9]{64}$|^[A-Fa-f0-9]{64}$"}
                    }
                },
                "signature":     {"type": "string", "description": "Base64-encoded detached Ed25519 signature of signedPayload."},
                "signedPayload": {"type": "string", "description": "Canonical JSON document signed by the publisher. Built by SignedPayloadBuilder (PHP) / sign.mjs (JS) — they MUST produce byte-identical output."},
                "keyId":         {"type": "string", "minLength": 1, "description": "Publisher key identifier. The host looks this up in SELFHELP_PLUGIN_TRUSTED_KEYS."},
                "changelogUrl":  {"type": "string", "format": "uri"}
            }
        }
    }
}
