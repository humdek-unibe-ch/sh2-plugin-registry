{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://humdek-unibe-ch.github.io/sh2-plugin-registry/registry.schema.json",
    "title": "SelfHelp plugin registry",
    "description": "Schema for registry.json files served as a SelfHelp plugin source.",
    "type": "object",
    "required": ["schemaVersion", "plugins"],
    "additionalProperties": false,
    "properties": {
        "schemaVersion": {
            "type": "string",
            "enum": ["1.0"]
        },
        "publishedAt": {
            "type": "string",
            "format": "date-time"
        },
        "publisher": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "name": { "type": "string", "minLength": 1 },
                "url":  { "type": "string", "format": "uri" }
            },
            "required": ["name"]
        },
        "plugins": {
            "type": "array",
            "items": { "$ref": "#/$defs/pluginEntry" }
        }
    },
    "$defs": {
        "pluginEntry": {
            "type": "object",
            "required": ["id", "name", "version", "trustLevel"],
            "additionalProperties": false,
            "properties": {
                "id":          { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
                "name":        { "type": "string", "minLength": 1 },
                "description": { "type": "string" },
                "version":     { "type": "string", "minLength": 1 },
                "channel":     { "type": "string", "enum": ["stable", "beta", "rc", "dev"] },
                "trustLevel":  { "type": "string", "enum": ["official", "reviewed", "untrusted"] },
                "homepage":    { "type": "string", "format": "uri" },
                "manifest":    { "type": "object" },
                "manifestUrl": { "type": "string", "format": "uri-reference" }
            },
            "anyOf": [
                { "required": ["manifest"] },
                { "required": ["manifestUrl"] }
            ]
        }
    }
}
